{
	"name": "@placeholderco/placeholder-ui",
	"version": "1.0.3",
	"description": "A modern, customizable Svelte 5 UI component library with comprehensive theming support",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PlaceholderUI/placeholder-ui.git"
	},
	"homepage": "https://github.com/PlaceholderUI/placeholder-ui#readme",
	"bugs": {
		"url": "https://github.com/PlaceholderUI/placeholder-ui/issues"
	},
	"keywords": [
		"svelte",
		"svelte5",
		"ui",
		"components",
		"design-system",
		"css-variables",
		"theming",
		"dark-mode"
	],
	"author": "Placeholderco",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"test": "vitest run"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./styles": {
			"import": "./dist/styles/index.css"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"jsdom": "^28.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"dayjs": "^1.11.20",
		"svelte-sonner": "^1.1.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
